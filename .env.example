# Copy this file to .env and fill in the values below.
# See README.md for the full list of optional tuning variables.

# Required
SEAHORSE_LIBRARY_PATH=./library
SEAHORSE_JWT_SECRET=change-me-to-a-long-random-string
SEAHORSE_TMDB_API_KEY=

# Optional (defaults shown)
SEAHORSE_PORT=8585
SEAHORSE_DB=sqlite.db
